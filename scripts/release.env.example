# Vorlage für scripts/release.env — kopieren und mit echten Werten füllen:
#   cp scripts/release.env.example scripts/release.env
#
# scripts/release.env ist in .gitignore (enthält Zugangsdaten). Diese .example
# bleibt im Repo, damit das Setup reproduzierbar ist.

# --- Code Signing ---
# Developer-ID-Application-Identität. Entweder der volle Name
#   "Developer ID Application: Dein Name (TEAMID)"
# oder (eindeutig, falls mehrere gleichnamige Zertifikate existieren) der
# SHA-1-Hash aus:  security find-identity -v -p codesigning
DEV_ID_APP="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# --- Notarisierung via App-Store-Connect-API-Key ---
# Key anlegen: appstoreconnect.apple.com -> Users and Access -> Integrations ->
#   App Store Connect API -> Key generieren (Access: Developer) -> .p8 downloaden.
# Die .p8 NICHT ins Repo legen (z.B. nach ~/.appstoreconnect/ ablegen, chmod 600).
NOTARY_KEY="$HOME/.appstoreconnect/AuthKey_XXXXXXXXXX.p8"
NOTARY_KEY_ID="XXXXXXXXXX"                                  # Key-ID (steht im Dateinamen)
NOTARY_ISSUER="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"        # Issuer-ID (UUID, oben auf der API-Keys-Seite)

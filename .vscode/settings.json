{
  // --- Swift / SourceKit-LSP (swiftlang.swift-vscode) ---------------------
  // Hintergrund-Indexierung an → Querverweise/Completion über das ganze Projekt.
  // Voraussetzung für VOLLE IntelliSense bei einem reinen .xcodeproj (kein
  // Package.swift): eine buildServer.json im Repo-Root, erzeugt mit
  //   xcode-build-server config -scheme schreibwerkstatt-focuseditor -project schreibwerkstatt-focuseditor.xcodeproj
  // (Tool via `brew install xcode-build-server`). Ohne sie kennt SourceKit-LSP
  // die Compile-Flags des Targets nicht und Completion bleibt eingeschränkt.
  "swift.sourcekit-lsp.backgroundIndexing": true,

  // --- Editor ---------------------------------------------------------------
  "[swift]": {
    "editor.defaultFormatter": "swiftlang.swift-vscode",
    "editor.formatOnSave": true,
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  },

  // --- Dateien / Suche: schwere Build-Artefakte ausblenden ------------------
  "files.associations": {
    "*.pbxproj": "plaintext",
    "*.xcscheme": "xml",
    "*.entitlements": "xml"
  },
  "files.exclude": {
    "**/.DS_Store": true,
    "build": true,
    "DerivedData": true
  },
  "search.exclude": {
    "build": true,
    "DerivedData": true,
    "**/*.xcuserstate": true
  },
  "files.watcherExclude": {
    "**/build/**": true,
    "**/DerivedData/**": true
  }
}
